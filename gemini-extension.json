{
  "name": "morning-ai",
  "version": "1.1.0",
  "description": "AI news tracking system. Tracks 80+ AI entities across 9 data sources and generates daily structured reports.",
  "settings": [
    {
      "name": "Extension Directory",
      "envVar": "GEMINI_EXTENSION_DIR",
      "sensitive": false
    },
    {
      "name": "ScrapeCreators API Key",
      "envVar": "SCRAPECREATORS_API_KEY",
      "sensitive": true
    },
    {
      "name": "GitHub Token",
      "envVar": "GITHUB_TOKEN",
      "sensitive": true
    },
    {
      "name": "YouTube API Key",
      "envVar": "YOUTUBE_API_KEY",
      "sensitive": true
    },
    {
      "name": "Discord Token",
      "envVar": "DISCORD_TOKEN",
      "sensitive": true
    },
    {
      "name": "Brave Search API Key",
      "envVar": "BRAVE_API_KEY",
      "sensitive": true
    },
    {
      "name": "Exa API Key",
      "envVar": "EXA_API_KEY",
      "sensitive": true
    },
    {
      "name": "Image Generation Provider (gemini/gpt/minimax/none)",
      "envVar": "IMAGE_GEN_PROVIDER",
      "sensitive": false
    },
    {
      "name": "Gemini/Imagen API Key",
      "envVar": "GEMINI_API_KEY",
      "sensitive": true
    },
    {
      "name": "OpenAI API Key (for image generation)",
      "envVar": "OPENAI_API_KEY",
      "sensitive": true
    },
    {
      "name": "MiniMax API Key",
      "envVar": "MINIMAX_API_KEY",
      "sensitive": true
    }
  ]
}
